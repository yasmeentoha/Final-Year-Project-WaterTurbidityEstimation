# ==========================================
# Main Secchi Disk Distance Estimation Code

import cv2
import os
import shutil
import zipfile
from roboflow import Roboflow
from google.colab import files

# --- 1. SETTINGS ---
API_KEY = "1sKPg7vTvvGj51OpPbhZ"
PROJECT_ID = "secchi-disk-detection"
VERSION = 17
INPUT_VIDEO = "/content/19.mp4"  # Update this for each video run
OUTPUT_VIDEO = "result19.mp4"
OUTPUT_FOLDER = "ambient_extracted_dataset19"

# --- 2. STANDARDIZED CONSTANTS ---
TARGET_WIDTH = 1280
TARGET_HEIGHT = 720
FOCAL_LENGTH = 996.9
REAL_DIAMETER = 20  # cm
DISAPPEARANCE_PATIENCE = 5

# --- 3. INITIALIZE ROBOFLOW ---
rf = Roboflow(api_key=API_KEY)
project = rf.workspace().project(PROJECT_ID)
model = project.version(VERSION).model

# Global tracking variables declaration (Initialize as None/Zero)
max_distance_recorded = 0.0
max_distance_frame_index = -1
last_bounding_box_distance = None
last_bounding_box_frame_index = -1
consecutive_missed_frames = 0

def process_inference(image, current_frame_idx=None):
    global max_distance_recorded, max_distance_frame_index
    global last_bounding_box_distance, last_bounding_box_frame_index
    global consecutive_missed_frames

    image_resized = cv2.resize(image, (TARGET_WIDTH, TARGET_HEIGHT))
    results = model.predict(image_resized, confidence=40).json()

    if results["predictions"]:
        consecutive_missed_frames = 0
        for p in results["predictions"]:
            p_width = max(p["width"], p["height"])
            distance = (REAL_DIAMETER * FOCAL_LENGTH) / p_width

            if current_frame_idx is not None:
                if distance > max_distance_recorded:
                    max_distance_recorded = distance
                    max_distance_frame_index = current_frame_idx

                last_bounding_box_distance = distance
                last_bounding_box_frame_index = current_frame_idx

            x1 = int(p["x"] - p["width"] / 2)
            y1 = int(p["y"] - p["height"] / 2)
            cv2.rectangle(image_resized, (x1, y1), (int(x1 + p["width"]), int(y1 + p["height"])), (0, 255, 0), 3)
            cv2.putText(image_resized, f"{round(distance, 1)}cm", (x1, y1 - 10),
                        cv2.FONT_HERSHEY_SIMPLEX, 1.2, (0, 255, 0), 3)
    else:
        if current_frame_idx is not None:
            consecutive_missed_frames += 1

    return image_resized

# --- 4. VIDEO EXECUTION LAYER ---
if os.path.exists(INPUT_VIDEO):
    # Reset memory variables for the new video stream
    max_distance_recorded = 0.0
    max_distance_frame_index = -1
    last_bounding_box_distance = None
    last_bounding_box_frame_index = -1
    consecutive_missed_frames = 0

    # Clean old images inside the folder from previous runs
    if os.path.exists(OUTPUT_FOLDER):
        shutil.rmtree(OUTPUT_FOLDER)
    os.makedirs(OUTPUT_FOLDER)

    cap = cv2.VideoCapture(INPUT_VIDEO)
    fps = cap.get(cv2.CAP_PROP_FPS)
    fourcc = cv2.VideoWriter_fourcc(*'mp4v')
    out = cv2.VideoWriter(OUTPUT_VIDEO, fourcc, fps, (TARGET_WIDTH, TARGET_HEIGHT))

    print(f"PHASE 1: Starting fresh scan for: {os.path.basename(INPUT_VIDEO)}")
    frame_count = 0
    early_exit_triggered = False
    patience_frame_buffer = []

    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break

        processed_frame = process_inference(frame, current_frame_idx=frame_count)
        out.write(processed_frame)

        if consecutive_missed_frames > 0:
            patience_frame_buffer.append(frame)
        else:
            patience_frame_buffer = []

        if consecutive_missed_frames >= DISAPPEARANCE_PATIENCE:
            early_exit_triggered = True
            break

        frame_count += 1

    # Close initial streams
    cap.release()

    # Determine final definitive reading using hierarchical priority logic
    if last_bounding_box_distance is not None:
        if max_distance_recorded > last_bounding_box_distance:
            final_turbidity_reading = max_distance_recorded
        else:
            final_turbidity_reading = last_bounding_box_distance

        final_reading_rounded = int(round(final_turbidity_reading, 0))
        print(f"-> Locked Turbidity Value for this file: {final_reading_rounded}cm")

        # PHASE 2: PROCESS REMAINING AMBIENT VIEWS
        print(f"PHASE 2: Checking standard ambient extraction paths...")
        ambient_sequence_counter = 1

        # Process standard buffer if early exit was caught
        if early_exit_triggered:
            for buffered_frame in patience_frame_buffer:
                ambient_resized = cv2.resize(buffered_frame, (TARGET_WIDTH, TARGET_HEIGHT))
                img_name = f"{final_reading_rounded}cm_{ambient_sequence_counter}.jpg"
                cv2.imwrite(os.path.join(OUTPUT_FOLDER, img_name), ambient_resized)
                ambient_sequence_counter += 1

            # Re-open stream to finish writing the rest of the clip out
            cap_remainder = cv2.VideoCapture(INPUT_VIDEO)
            cap_remainder.set(cv2.CAP_PROP_POS_FRAMES, frame_count)
            while cap_remainder.isOpened():
                ret, frame = cap_remainder.read()
                if not ret:
                    break
                ambient_resized = cv2.resize(frame, (TARGET_WIDTH, TARGET_HEIGHT))
                img_name = f"{final_reading_rounded}cm_{ambient_sequence_counter}.jpg"
                cv2.imwrite(os.path.join(OUTPUT_FOLDER, img_name), ambient_resized)
                out.write(ambient_resized)
                ambient_sequence_counter += 1
            cap_remainder.release()

        # --- REVOLUTIONARY FIX: ROBUST HISTORICAL FALLBACK FOR SHORT CLIPS ---
        harvested_count = len(os.listdir(OUTPUT_FOLDER))
        if harvested_count == 0:
            print(f"\n[FALLBACK TRIGGERED] Video stream concluded before hitting disappearance criteria.")
            print(f"Re-opening original stream to extract clean, cropped background quadrants...")

            cap_fallback = cv2.VideoCapture(INPUT_VIDEO)
            fallback_extracted = 0

            # Extract from the first 5 frames of the video
            while cap_fallback.isOpened() and fallback_extracted < 5:
                ret, frame = cap_fallback.read()
                if not ret:
                    break

                h, w, _ = frame.shape
                # Crop away from the center: capture the left 40% quadrant of pure water background
                crop_x1, crop_y1 = 0, 0
                crop_x2, crop_y2 = int(w * 0.4), h
                cropped_ambient = frame[crop_y1:crop_y2, crop_x1:crop_x2]

                # Resize to target output rules
                ambient_resized = cv2.resize(cropped_ambient, (TARGET_WIDTH, TARGET_HEIGHT))
                img_name = f"{final_reading_rounded}cm_fallback_{ambient_sequence_counter}.jpg"
                cv2.imwrite(os.path.join(OUTPUT_FOLDER, img_name), ambient_resized)

                ambient_sequence_counter += 1
                fallback_extracted += 1

            cap_fallback.release()
            print(f"Fallback complete! Successfully extracted {fallback_extracted} cropped water backgrounds.")
        else:
            print(f"Success: Harvested {harvested_count} regular ambient frames.")
    else:
        print("\nError: Could not calculate a baseline distance for this video file.")

    out.release()

    # --- PHASE 3: COMPRESS AND TRIGGER AUTO-DOWNLOAD ---
    if last_bounding_box_distance is not None:
        zip_filename = f"Ambient_Frames_{final_reading_rounded}cm.zip"
        print(f"PHASE 3: Compressing into '{zip_filename}'...")

        with zipfile.ZipFile(zip_filename, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for root, _, files_list in os.walk(OUTPUT_FOLDER):
                for file in files_list:
                    zipf.write(os.path.join(root, file), arcname=file)

        print("Triggering browser download...")
        files.download(zip_filename)
else:
    print(f"Error: Target input video path does not exist: {INPUT_VIDEO}")
