import os
import re
import glob
import zipfile
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# --- 1. UNZIP CONFIGURATION ---
ZIP_PATH = "/content/revised_ambient_dataset.zip"  # Path to your zip file
EXTRACT_DIR = "/content/extracted_dataset7"          # Where Colab will unzip it

# Automatically extract the zip file if it hasn't been extracted yet
if os.path.exists(ZIP_PATH):
    print(f"Extracting {ZIP_PATH}...")
    with zipfile.ZipFile(ZIP_PATH, 'r') as zip_ref:
        zip_ref.extractall(EXTRACT_DIR)
    print("Extraction complete!")
else:
    print(f"Error: Could not find zip file at {ZIP_PATH}")

# --- 2. RECURSIVE SEARCH ---
# The '**' pattern allows it to search deeply through:
# extracted_dataset/revised_ambient_dataset/turbidity_folder/images.jpg
search_pattern = os.path.join(EXTRACT_DIR, "**", "*.jpg")
all_image_paths = glob.glob(search_pattern, recursive=True)

parsed_distances = []

for path in all_image_paths:
    filename = os.path.basename(path)
    # Checks the actual image filename for the digits before 'cm'
    match = re.match(r"^(\d+)cm", filename)
    if match:
        distance_val = int(match.group(1))
        parsed_distances.append(distance_val)

# Convert to a DataFrame for analysis
df_dist = pd.DataFrame(parsed_distances, columns=["Turbidity_cm"])

# --- 3. DISPLAY STATISTICAL SUMMARY ---
print(f"\n=== Dataset Distribution Summary ===")
print(f"Total Ambient Frames Found:  {len(df_dist)}")
if not df_dist.empty:
    print(f"Minimum Distance:            {df_dist['Turbidity_cm'].min()} cm")
    print(f"Maximum Distance:            {df_dist['Turbidity_cm'].max()} cm")
    print(f"Average (Mean) Distance:     {df_dist['Turbidity_cm'].mean():.2f} cm")
    print(f"Median Distance:             {df_dist['Turbidity_cm'].median()} cm")
else:
    print("\n[!] Warning: No matching images found!")
    print("Double check that your actual image filenames look like '35cm_1.jpg'")
    print("If your image filenames are generic (like 'frame1.jpg') and ONLY the folders are named '35cm', let me know!")

# --- 4. PLOT THE DISTRIBUTION ---
if not df_dist.empty:
    plt.figure(figsize=(10, 6))
    sns.set_theme(style="whitegrid")

    sns.histplot(
        data=df_dist,
        x="Turbidity_cm",
        kde=True,
        bins=15,
        color="#1f77b4",
        edgecolor="black",
        alpha=0.7
    )

    plt.title("Distribution of Extracted Ambient Data Across Turbidity Levels", fontsize=14, pad=15, fontweight='bold')
    plt.xlabel("Estimated Turbidity Value (Secchi Depth in cm)", fontsize=12, labelpad=10)
    plt.ylabel("Total Extracted Frame Count", fontsize=12, labelpad=10)

    plt.tight_layout()
    plt.show()
