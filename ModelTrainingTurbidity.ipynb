# Dataset Load

import os
import re
import glob
import zipfile
import pandas as pd

# --- 1. UNZIP DATASET ---
ZIP_PATH = "/content/revised_ambient_dataset.zip" #modify zip file path
EXTRACT_DIR = "/content/extracted_dataset1" # output of the extracted zip file

if os.path.exists(ZIP_PATH):
    print(f"Extracting {ZIP_PATH}...")
    with zipfile.ZipFile(ZIP_PATH, 'r') as zip_ref:
        zip_ref.extractall(EXTRACT_DIR)
    print("Extraction complete!")
else:
    raise FileNotFoundError(f"Could not find zip file at {ZIP_PATH}")

# --- 2. CASE-INSENSITIVE RECURSIVE SEARCH ---
# Using recursive=True and checking multiple extensions handles any folder structure or casing
all_image_paths = []
for ext in ["*.jpg", "*.JPG", "*.jpeg", "*.JPEG"]:
    search_pattern = os.path.join(EXTRACT_DIR, "**", ext)
    all_image_paths.extend(glob.glob(search_pattern, recursive=True))

data_records = []
for path in all_image_paths:
    filename = os.path.basename(path)
    match = re.match(r"^(\d+)cm", filename)
    if match:
        distance_val = int(match.group(1))
        data_records.append({"image_path": path, "turbidity": distance_val})

# --- 3. SAFETY CHECK FOR EMPTY DATA ---
if len(data_records) == 0:
    print("\n[!] ERROR: Still mapped 0 images. Let's debug:")
    # Print the first few files actually inside the directory to see where they are
    all_files = []
    for root, dirs, files in os.walk(EXTRACT_DIR):
        for file in files[:5]:
            all_files.append(os.path.join(root, file))
    print("Here is a sample of what is actually inside the zip:")
    for f in all_files:
        print(f" - {f}")
    raise ValueError("No matching 'XXcm' images found. Review the file paths printed above.")

df_raw = pd.DataFrame(data_records)
print(f"Total raw images successfully mapped: {len(df_raw)}")

# --- 4. DYNAMIC BALANCING (2000-2500 CAP) ---
MIN_THRESHOLD = 2000
MAX_THRESHOLD = 2500
balanced_records = []

unique_classes = df_raw['turbidity'].unique()

print("\n--- Applying Balanced Thresholds ---")
for t_class in sorted(unique_classes):
    class_subset = df_raw[df_raw['turbidity'] == t_class]
    current_count = len(class_subset)

    if current_count > MAX_THRESHOLD:
        adjusted_subset = class_subset.sample(n=MAX_THRESHOLD, random_state=42)
        balanced_records.append(adjusted_subset)
        print(f"Class {t_class}cm: Capped down from {current_count} to {MAX_THRESHOLD}")
    elif current_count < MIN_THRESHOLD:
        adjusted_subset = class_subset.sample(n=MIN_THRESHOLD, replace=True, random_state=42)
        balanced_records.append(adjusted_subset)
        print(f"Class {t_class}cm: Oversampled up from {current_count} to {MIN_THRESHOLD}")
    else:
        balanced_records.append(class_subset)
        print(f"Class {t_class}cm: Kept as-is ({current_count} frames)")

train_ready_df = pd.concat(balanced_records).reset_index(drop=True)
print(f"\nFinal optimized dataset manifest size: {len(train_ready_df)} frames.")

#=============================================================

# Main ML model training code

import tensorflow as tf
from tensorflow.keras import layers, models
from sklearn.model_selection import train_test_split

# 1. Train/Validation Split with Stratification
train_df, val_df = train_test_split(
    train_ready_df,
    test_size=0.2,
    random_state=42,
    stratify=train_ready_df['turbidity']
)

IMG_SIZE = (224, 224)
BATCH_SIZE = 32

# 2. Preprocessing & Augmentation Pipelines
def load_and_preprocess_image(path, label):
    img = tf.io.read_file(path)
    img = tf.image.decode_jpeg(img, channels=3)
    img = tf.image.resize(img, IMG_SIZE)
    return img, tf.cast(label, tf.float32)

def apply_augmentation(img, label):
    img = tf.image.random_flip_left_right(img)
    img = tf.image.random_brightness(img, max_delta=0.1)
    img = tf.image.random_contrast(img, lower=0.9, upper=1.1)
    return img, label

# Create TensorFlow Datasets
train_ds = tf.data.Dataset.from_tensor_slices((train_df['image_path'].values, train_df['turbidity'].values))
train_ds = train_ds.shuffle(buffer_size=len(train_df), seed=42)
train_ds = train_ds.map(load_and_preprocess_image, num_parallel_calls=tf.data.AUTOTUNE)
train_ds = train_ds.map(apply_augmentation, num_parallel_calls=tf.data.AUTOTUNE)
train_ds = train_ds.batch(BATCH_SIZE).prefetch(buffer_size=tf.data.AUTOTUNE)

val_ds = tf.data.Dataset.from_tensor_slices((val_df['image_path'].values, val_df['turbidity'].values))
val_ds = val_ds.map(load_and_preprocess_image, num_parallel_calls=tf.data.AUTOTUNE)
val_ds = val_ds.batch(BATCH_SIZE).prefetch(buffer_size=tf.data.AUTOTUNE)

# 3. Network Architecture
base_model = tf.keras.applications.MobileNetV3Large(
    input_shape=(IMG_SIZE[0], IMG_SIZE[1], 3),
    include_top=False,
    weights='imagenet',
    pooling='avg'
)
base_model.trainable = False  # Freeze pre-trained feature extractor layers

model = models.Sequential([
    base_model,
    layers.Dense(128, activation='relu'),
    layers.Dropout(0.3),
    layers.Dense(64, activation='relu'),
    layers.Dense(1, activation='linear')
])

# 4. Compilation with Huber Loss to handle multi-modal gap bias
model.compile(
    optimizer=tf.keras.optimizers.Adam(learning_rate=1e-3),
    loss=tf.keras.losses.Huber(delta=1.0),
    metrics=['mae', 'mse']
)

# 5. Training Callbacks & Execution
callbacks = [
    tf.keras.callbacks.EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True),
    tf.keras.callbacks.ModelCheckpoint('best_turbidity_cnn.keras', monitor='val_loss', save_best_only=True)
]

print("\nStarting CNN regression training...")
history = model.fit(
    train_ds,
    validation_data=val_ds,
    epochs=20,
    callbacks=callbacks
)
print("\nModel training execution concluded successfully!")

# --- 6. DOWNLOAD TRAINED MODEL TO LOCAL MACHINE ---
print("Triggering model download to your local machine...")
from google.colab import files

# This grabs the file saved by your ModelCheckpoint callback
files.download('best_turbidity_cnn.keras')

#============================================================
# Evaluation Code

import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score, confusion_matrix

print("Evaluating model performance on validation dataset...")

# --- 1. GENERATE PREDICTIONS ---
# Extract true labels and paths from the validation split
y_true = val_df['turbidity'].values

# Use the trained model to predict values on the validation pipeline
# val_ds returns (images, labels), we extract just the predictions
y_pred = model.predict(val_ds).flatten()

# --- 2. CALCULATE STANDARD REGRESSION METRICS ---
mae = mean_absolute_error(y_true, y_pred)
mse = mean_squared_error(y_true, y_pred)
rmse = np.sqrt(mse)
r2 = r2_score(y_true, y_pred)

print("\n========================= PERFORMANCE METRICS =========================")
print(f"Mean Absolute Error (MAE):      {mae:.2f} cm  (On average, predictions miss by this much)")
print(f"Mean Squared Error (MSE):        {mse:.2f}")
print(f"Root Mean Squared Error (RMSE):  {rmse:.2f} cm (Penalizes larger outlier errors more heavily)")
print(f"R² Score (Coefficient of Det.):  {r2:.4f}     (1.0 is perfect; variance explained by model)")
print("=======================================================================\n")

# --- 3. PLOT ACTUAL VS. PREDICTED (REGRESSION PLOT) ---
plt.figure(figsize=(15, 5))

plt.subplot(1, 2, 1)
sns.scatterplot(x=y_true, y=y_pred, alpha=0.5, color='#1f77b4')
# Draw a perfect diagonal 1:1 prediction reference line
max_val = int(max(max(y_true), max(y_pred)))
min_val = int(min(min(y_true), min(y_pred)))
plt.plot([min_val, max_val], [min_val, max_val], color='red', linestyle='--', label='Perfect Predictions')

plt.title("Actual vs. Predicted Turbidity Values", fontsize=12, fontweight='bold')
plt.xlabel("True Secchi Depth (cm)", fontsize=10)
plt.ylabel("Predicted Secchi Depth (cm)", fontsize=10)
plt.legend()
plt.grid(True, alpha=0.3)

# --- 4. PLOT BINNED CATEGORICAL CONFUSION MATRIX ---
# Because continuous numbers can't make a standard confusion matrix,
# we map them into logical brackets to fulfill academic committee expectations.
def map_to_bracket(val):
    if val <= 35: return "Highly Turbid (22-35cm)"
    elif val <= 65: return "Mid Turbid (36-65cm)"
    elif val <= 100: return "Clearer (66-100cm)"
    else: return "Pristine (200cm+)"

brackets = ["Highly Turbid (22-35cm)", "Mid Turbid (36-65cm)", "Clearer (66-100cm)", "Pristine (200cm+)"]

y_true_bracket = [map_to_bracket(v) for v in y_true]
y_pred_bracket = [map_to_bracket(v) for v in y_pred]

cm = confusion_matrix(y_true_bracket, y_pred_bracket, labels=brackets)

plt.subplot(1, 2, 2)
sns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=brackets, yticklabels=brackets)
plt.title("Binned Classification Confusion Matrix", fontsize=12, fontweight='bold')
plt.xlabel("Predicted Environment Category", fontsize=10)
plt.ylabel("True Environment Category", fontsize=10)
plt.xticks(rotation=45, ha='right')

plt.tight_layout()
plt.show()

