# Model Testing Code
import cv2
import numpy as np
import tensorflow as tf
from tqdm import tqdm

# --- 1. CONFIGURATION AND SETUPS ---
VIDEO_INPUT_PATH = "/content/1.mp4"       # Put your raw video path here
VIDEO_OUTPUT_PATH = "/content/predicted_turbidity2.mp4" # Where the final annotated video will save
MODEL_PATH = "best_turbidity_cnn.keras"               # Your saved model file
IMG_SIZE = (224, 224)                                  # Must match training size

# Load your trained model
print("Loading trained Turbidity CNN Model...")
model = tf.keras.models.load_model(MODEL_PATH)

# Open the video file
cap = cv2.VideoCapture(VIDEO_INPUT_PATH)
if not cap.isOpened():
    raise FileNotFoundError(f"Error: Could not open video file at {VIDEO_INPUT_PATH}")

# Get original video properties
fps = int(cap.get(cv2.CAP_PROP_FPS))
width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))

# Set up the video writer to save the results
fourcc = cv2.VideoWriter_fourcc(*'mp4v')
out = cv2.VideoWriter(VIDEO_OUTPUT_PATH, fourcc, fps, (width, height))

print(f"Processing Video: {total_frames} frames @ {fps} FPS...")

# --- 2. FRAME-BY-FRAME INFERENCE LOOP ---
# tqdm gives you a nice progress bar in Colab so you know how long it will take
for _ in tqdm(range(total_frames)):
    ret, frame = cap.read()
    if not ret:
        break # Break if the video ends unexpectedly

    # Preprocess the frame for the model
    # Convert Binarized OpenCV BGR format to standard RGB format
    rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    resized_frame = cv2.resize(rgb_frame, IMG_SIZE)

    # Expand dimensions to add the batch size channel: (1, 224, 224, 3)
    input_tensor = np.expand_dims(resized_frame, axis=0)

    # Run prediction
    prediction = model.predict(input_tensor, verbose=0)
    predicted_val = float(prediction[0][0])

    # --- 3. ANNOTATE THE VIDEO FRAME ---
    # Define an overlay category text based on the prediction thresholds
    if predicted_val <= 35:
        status_text = "Highly Turbid"
        color = (0, 0, 255) # Red text in BGR format
    elif predicted_val <= 65:
        status_text = "Moderately Turbid"
        color = (0, 165, 255) # Orange text
    elif predicted_val <= 100:
        status_text = "Slightly Clear"
        color = (255, 255, 0) # Cyan/Yellow text
    else:
        status_text = "Pristine Clarity"
        color = (0, 255, 0) # Green text

    # Burn metrics onto the video frame
    display_string = f"Est. Secchi Depth: {predicted_val:.1f} cm ({status_text})"

    # Add a clean black shadow/background banner behind text for premium readability
    cv2.rectangle(frame, (15, 20), (700, 75), (0, 0, 0), -1)

    # Write the main text overlay onto the live array frame
    cv2.putText(
        frame,
        display_string,
        (30, 55),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.9,
        color,
        2,
        cv2.LINE_AA
    )

    # Write the frame into the new video container file
    out.write(frame)

# Clean up all system threads safely
cap.release()
out.release()
print(f"\nProcessing Complete! Annotated video saved as: {VIDEO_OUTPUT_PATH}")
